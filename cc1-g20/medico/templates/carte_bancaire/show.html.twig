{% extends 'base.html.twig' %}

{% block title %}CarteBancaire{% endblock %}

{% block body %}
    <h1>CarteBancaire</h1>

    <table class="grid-table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ carte_bancaire.id }}</td>
            </tr>
            <tr>
                <th>Prenom</th>
                <td>{{ carte_bancaire.prenom }}</td>
            </tr>
