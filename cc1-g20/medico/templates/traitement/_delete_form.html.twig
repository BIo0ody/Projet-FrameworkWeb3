<form method="post" action="{{ path('app_traitement_delete', {'consultationId': consultationId, 'id': traitement.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce traitement ?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ traitement.id) }}">
    <button class="btn btn-danger">Supprimer</button>
</form>
