<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Welcome!{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">

        {% block stylesheets %}
            <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.1/dist/css/bootstrap.min.css" rel="stylesheet">
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.1/dist/js/bootstrap.bundle.min.js"></script>
        {% endblock %}
    </head>
    <body>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
            <div class="container">
                <a class="navbar-brand" href="{{ path('app_home') }}">MedicoApp</a>
                <div class="collapse navbar-collapse">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_about') }}">A propros</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_consultation_index') }}">Consultations</a>
                        </li>

                        {% if is_granted('ROLE_ADMIN')  or is_granted('ROLE_MEDECIN') %}
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('app_consultation_new') }}">Nouvelle Consultation</a>
                            </li>
                        {% endif %}

                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_traitement_all') }}">Mes Traitements</a>
                        </li>

                        {% if is_granted('ROLE_MEDECIN') %}
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('app_user_patients') }}">Mes Patients</a>
                            </li>
                        {% endif %}

                        {% if is_granted('ROLE_PATIENT') %}
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('app_user_medecins') }}">Mes Médecins</a>
                            </li>
                        {% endif %}

                        {% if is_granted('ROLE_ADMIN') %}
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('app_user_index') }}">Tous les utilisateurs</a>
                            </li>
                        {% endif %}
                        
                    </ul>
                    <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                        {% if app.user is null %}
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('app_login') }}">Se connecter</a>
                            </li>
                        {% else %}
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('app_carte_bancaire_index') }}" >{{ app.user.email }}</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('app_logout') }}">Se Déconnecter</a>
                            </li>
                        {% endif %}
                    </ul>
                </div>
            </div>
        </nav>

        <div class="container">
            {% block body %}{% endblock %}
        </div>
    </body>
</html>
